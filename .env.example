# NextGenCV Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Django ────────────────────────────────────────────────────────────────────
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of allowed CORS origins (required in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (default for dev)
# DATABASE_URL=postgres://user:password@localhost:5432/nextgencv

# ── Redis + Celery ────────────────────────────────────────────────────────────
# Required for async PDF parsing, AI optimization, and email sending
# Install Redis: https://redis.io/docs/getting-started/
# Or run with Docker: docker run -p 6379:6379 redis
REDIS_URL=redis://localhost:6379/0

# ── OpenAI (AI features) ──────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Leave blank to use rule-based fallback (app works without this)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1500
OPENAI_TEMPERATURE=0.7

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Dev default: leave EMAIL_BACKEND unset → emails print to console (no SMTP needed)
# Production: uncomment and fill in your SMTP credentials
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to Google Account → Security → App passwords → generate one for "Mail"
#   3. Use that 16-char app password as EMAIL_HOST_PASSWORD (NOT your Gmail password)
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-gmail@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=NextGenCV <your-gmail@gmail.com>

# ── Google SSO ────────────────────────────────────────────────────────────────
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application)
# Authorised redirect URI: http://localhost:8000/auth/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LinkedIn SSO ──────────────────────────────────────────────────────────────
# Setup: https://www.linkedin.com/developers/apps
# Enable product: "Sign In with LinkedIn using OpenID Connect"
# Authorised redirect URL: http://localhost:8000/auth/linkedin_oauth2/login/callback/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Media files ───────────────────────────────────────────────────────────────
# Where uploaded PDFs are stored (defaults to ./media)
# MEDIA_ROOT=/var/www/nextgencv/media

# ── Environment tag ───────────────────────────────────────────────────────────
# Set to 'production' to enable ManifestStaticFilesStorage and other prod settings
# DJANGO_ENV=production
